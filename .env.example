# ============================================================
# PostgreSQL
# ============================================================
PG_USER=iax_user
PG_PASSWORD=changeme
PG_DB=interview_agent
PG_PORT=5432

# ============================================================
# MinIO
# ============================================================
MINIO_USER=minioadmin
MINIO_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ============================================================
# Milvus
# ============================================================
MILVUS_PORT=19530
MILVUS_GRPC_PORT=9091

# ============================================================
# DeepSeek API
# ============================================================
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL_CHAT=deepseek-chat
DEEPSEEK_MODEL_REASONER=deepseek-reasoner

# ============================================================
# 硅基流动 (SiliconFlow) — Embedding 向量模型
# API文档: https://docs.siliconflow.cn
# ============================================================
EMBEDDING_API_KEY=sk-your-siliconflow-api-key
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-8B
EMBEDDING_DIM=4096

# ============================================================
# OCR API — 硅基流动 deepseek-ai/DeepSeek-OCR
# API文档: https://api-docs.siliconflow.cn/docs/api/chat-completions-post
# 通过 Chat Completions 多模态接口传入图片，模型返回文字识别结果
# ============================================================
OCR_API_KEY=sk-your-siliconflow-api-key
OCR_BASE_URL=https://api.siliconflow.cn/v1
OCR_MODEL=deepseek-ai/DeepSeek-OCR

# ============================================================
# STT (Speech-to-Text) — 硅基流动 FunAudioLLM/SenseVoiceSmall
# API文档: https://docs.siliconflow.cn/docs/api/audio-transcriptions-post
# ============================================================
STT_API_KEY=sk-your-siliconflow-api-key
STT_BASE_URL=https://api.siliconflow.cn/v1
STT_MODEL=FunAudioLLM/SenseVoiceSmall

# ============================================================
# Proxy (for China mainland network)
# ============================================================
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1,postgres,milvus,minio,etcd

# ============================================================
# App
# ============================================================
ENVIRONMENT=production
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:8080
BACKEND_PORT=8000
FRONTEND_PORT=8080
VITE_API_BASE_URL=/api
VITE_WS_URL=ws://localhost:8000
